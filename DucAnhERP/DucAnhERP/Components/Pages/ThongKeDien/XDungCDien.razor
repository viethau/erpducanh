    // Xử lý paging
    private List<D_XDungCDienModel> Paging(List<D_XDungCDienModel> DM_TuyenDuongs)
    {
        // Đếm số bản ghi thỏa mãn
        var count = DM_TuyenDuongs.Count();

        // Lọc bản ghi theo page hiện tại và page size
        DM_TuyenDuongs = DM_TuyenDuongs.Skip((dmModel.PageNumber - 1) * dmModel.PageSize).Take(dmModel.PageSize).ToList();

        // Xóa danh sách đang hiển thị trên màn hình
        listD_XDungCDienModel.Clear();

        // Thêm những bản ghi sau khi lọc vào danh sách hiển thị
        foreach (var ndm in DM_TuyenDuongs)
        {
            listD_XDungCDienModel.Add(ndm);
        }

        // Tạo pagelist mới
        var pagelist = new PageList<D_XDungCDienModel>(listD_XDungCDienModel, count, dmModel.PageNumber, dmModel.PageSize);
        MetaData = pagelist.MetaData;
        return DM_TuyenDuongs;
    }


